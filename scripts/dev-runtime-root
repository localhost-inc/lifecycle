#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_NAME="$(basename "$REPO_ROOT")"
REPO_SLUG="$(printf '%s' "$REPO_NAME" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-{2,}/-/g')"
REPO_SLUG="${REPO_SLUG:-repo}"
REPO_HASH="$(printf '%s' "$REPO_ROOT" | cksum | awk '{print $1}')"

printf '%s/.lifecycle/dev/%s-%s\n' "$HOME" "$REPO_SLUG" "$REPO_HASH"
