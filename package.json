{
  "name": "lifecycle",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localhost-inc/lifecycle.git"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^22.13.10",
    "github-markdown-css": "^5.9.0",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.17.0",
    "turbo": "^2.8.0",
    "typescript": "^5.9.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "bugs": {
    "url": "https://github.com/localhost-inc/lifecycle/issues"
  },
  "description": "Terminal-native workspace runtime for local-first software work.",
  "engines": {
    "bun": ">=1.3.10"
  },
  "homepage": "https://github.com/localhost-inc/lifecycle",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "bench:naming": "bun run scripts/benchmark-naming-models.ts",
    "build": "turbo run build",
    "dev": "./scripts/dev",
    "dev:desktop": "./scripts/dev desktop",
    "dev:desktop-mac": "bun run dev:desktop",
    "dev:desktop:services": "./scripts/dev desktop-services",
    "dev:tui": "./scripts/dev tui",
    "dev:tui:local": "./scripts/dev tui --local",
    "format": "oxfmt --write apps packages",
    "format:check": "oxfmt --check apps packages",
    "lint": "turbo run lint",
    "lint:force": "turbo run lint --force",
    "desktop:mac": "./apps/desktop-mac/scripts/open.sh",
    "desktop:mac:smoke": "./scripts/dev desktop-smoke",
    "desktop:mac:xcode-env": "./apps/desktop-mac/scripts/xcode-env.sh",
    "prepare": "lefthook install",
    "qa": "bun run qa:js",
    "qa:js": "turbo run lint typecheck test --parallel",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "typecheck:force": "turbo run typecheck --force"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react-virtuoso": "^4.18.3"
  }
}
