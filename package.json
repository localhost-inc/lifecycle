{
  "name": "lifecycle",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@lifecycle/desktop --filter=@lifecycle/worker",
    "format": "oxfmt --write apps packages",
    "format:check": "oxfmt --check apps packages",
    "lint": "turbo run lint",
    "prepare": "lefthook install",
    "qa": "sh -c 'bun run qa:js & p1=$!; bun run test:rust & p2=$!; wait $p1; s1=$?; wait $p2; s2=$?; [ $s1 -eq 0 ] && [ $s2 -eq 0 ]'",
    "qa:js": "turbo run lint typecheck test --parallel",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^22.13.10",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.17.0",
    "turbo": "^2.8.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
