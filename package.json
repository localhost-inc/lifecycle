{
  "name": "lifecycle",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localhost-inc/lifecycle.git"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/node": "^22.13.10",
    "desktop": "^0.1.0",
    "github-markdown-css": "^5.9.0",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.17.0",
    "turbo": "^2.8.0",
    "typescript": "^5.9.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "bugs": {
    "url": "https://github.com/localhost-inc/lifecycle/issues"
  },
  "description": "Desktop-first workspace runtime for local-first software work.",
  "engines": {
    "bun": ">=1.3.10"
  },
  "homepage": "https://github.com/localhost-inc/lifecycle",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "bench:naming": "bun run scripts/benchmark-naming-models.ts",
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@lifecycle/desktop --filter=@lifecycle/api --filter=@lifecycle/www",
    "format": "oxfmt --write apps packages",
    "format:check": "oxfmt --check apps packages",
    "lint": "turbo run lint",
    "lint:force": "turbo run lint --force",
    "prepare": "lefthook install",
    "qa": "sh -c 'bun run qa:js & p1=$!; bun run test:rust & p2=$!; wait $p1; s1=$?; wait $p2; s2=$?; [ $s1 -eq 0 ] && [ $s2 -eq 0 ]'",
    "qa:js": "turbo run lint typecheck test --parallel",
    "test:rust": "cargo test --workspace",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "typecheck:force": "turbo run typecheck --force"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "react-virtuoso": "^4.18.3"
  }
}
