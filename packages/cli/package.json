    "@lifecycle/cmd": "workspace:*",
    "@lifecycle/contracts": "workspace:*",
    "@lifecycle/db": "workspace:*",
    "@lifecycle/workspace": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "hono": "^4.7.0",
    "routedjs": "^0.0.5",
    "zod": "^4.3.6"
  }
