{
  "name": "@lifecycle/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "lifecycle": "./src/index.ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
