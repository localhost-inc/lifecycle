{
  "extends": "../config/tsconfig.package.json",
  "compilerOptions": {
    "rootDir": "../..",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "types": ["node", "bun"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "references": [{ "path": "../../apps/control-plane" }]
}
