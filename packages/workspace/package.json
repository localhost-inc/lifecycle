{
  "name": "@lifecycle/workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./src/client/index.ts"
    },
    "./react": {
      "types": "./src/client/react.ts",
      "default": "./src/client/react.ts"
    },
    "./client/react": {
      "types": "./src/client/react.ts",
      "default": "./src/client/react.ts"
    },
    "./policy": {
      "types": "./src/policy/index.ts",
      "default": "./src/policy/index.ts"
    },
    "./internal/local": {
      "types": "./src/clients/local/index.ts",
      "default": "./src/clients/local/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "oxfmt src",
    "lint": "oxlint src",
    "test": "bun test src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lifecycle/contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.1.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
