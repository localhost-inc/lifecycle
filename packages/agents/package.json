{
  "name": "@lifecycle/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
"./internal/messages": {
      "types": "./src/session/messages.ts",
      "default": "./src/session/messages.ts"
    },
    "./internal/handle": {
      "types": "./src/handle.ts",
      "default": "./src/handle.ts"
    },
    "./internal/process": {
      "types": "./src/process.ts",
      "default": "./src/process.ts"
    },
    "./internal/stream-protocol": {
      "types": "./src/stream-protocol.ts",
      "default": "./src/stream-protocol.ts"
    },
    "./internal/providers/claude/auth": {
      "types": "./src/providers/claude/auth.ts",
      "default": "./src/providers/claude/auth.ts"
    },
    "./internal/providers/claude/catalog": {
      "types": "./src/providers/claude/catalog.ts",
      "default": "./src/providers/claude/catalog.ts"
    },
    "./internal/providers/claude/provider": {
      "types": "./src/providers/claude/provider.ts",
      "default": "./src/providers/claude/provider.ts"
    },
    "./internal/providers/codex/auth": {
      "types": "./src/providers/codex/auth.ts",
      "default": "./src/providers/codex/auth.ts"
    },
    "./internal/providers/codex/catalog": {
      "types": "./src/providers/codex/catalog.ts",
      "default": "./src/providers/codex/catalog.ts"
    },
    "./internal/providers/codex/provider": {
      "types": "./src/providers/codex/provider.ts",
      "default": "./src/providers/codex/provider.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "oxfmt src",
    "lint": "oxlint src",
    "test": "bun test src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@lifecycle/contracts": "workspace:*",
    "@openai/codex-sdk": "^0.116.0"
  }
}
