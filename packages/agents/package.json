{
  "name": "@lifecycle/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./react": {
      "types": "./src/react.ts",
      "default": "./src/react.ts"
    },
    "./providers/claude/auth": {
      "types": "./src/providers/claude/auth.ts",
      "default": "./src/providers/claude/auth.ts"
    },
    "./providers/claude/catalog": {
      "types": "./src/providers/claude/catalog.ts",
      "default": "./src/providers/claude/catalog.ts"
    },
    "./providers/claude/worker": {
      "types": "./src/providers/claude/worker.ts",
      "default": "./src/providers/claude/worker.ts"
    },
    "./providers/codex/auth": {
      "types": "./src/providers/codex/auth.ts",
      "default": "./src/providers/codex/auth.ts"
    },
    "./providers/codex/catalog": {
      "types": "./src/providers/codex/catalog.ts",
      "default": "./src/providers/codex/catalog.ts"
    },
    "./providers/codex/worker": {
      "types": "./src/providers/codex/worker.ts",
      "default": "./src/providers/codex/worker.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "oxfmt src",
    "lint": "oxlint src",
    "test": "bun test src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@lifecycle/contracts": "workspace:*",
    "@lifecycle/workspace": "workspace:*",
    "@openai/codex-sdk": "^0.116.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "react": "^19.2.4"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
