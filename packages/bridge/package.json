{
  "name": "@lifecycle/bridge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "generate": "bun run node_modules/routedjs/src/cli/index.ts generate",
    "build": "tsc -b tsconfig.json",
    "format": "oxfmt src",
    "lint": "oxlint src",
    "test": "bun test src --pass-with-no-tests",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@lifecycle/contracts": "workspace:*",
    "@lifecycle/control-plane": "workspace:*",
    "@lifecycle/db": "workspace:*",
    "@lifecycle/stack": "workspace:*",
    "@lifecycle/workspace": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "hono": "^4.7.10",
    "routedjs": "0.1.4",
    "zod": "^4.3.6"
  }
}
