{
  "name": "@lifecycle/bridge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./workspace": {
      "types": "./src/domains/workspace/index.ts",
      "default": "./src/domains/workspace/index.ts"
    },
    "./workspace/host": {
      "types": "./src/domains/workspace/host.ts",
      "default": "./src/domains/workspace/host.ts"
    },
    "./workspace/hosts/cloud": {
      "types": "./src/domains/workspace/hosts/cloud/index.ts",
      "default": "./src/domains/workspace/hosts/cloud/index.ts"
    },
    "./workspace/hosts/local": {
      "types": "./src/domains/workspace/hosts/local/index.ts",
      "default": "./src/domains/workspace/hosts/local/index.ts"
    },
    "./stack": {
      "types": "./src/domains/stack/index.ts",
      "default": "./src/domains/stack/index.ts"
    },
    "./runtime-paths": {
      "types": "./src/lib/runtime-paths.ts",
      "default": "./src/lib/runtime-paths.ts"
    },
    "./server": {
      "types": "./src/lib/server.ts",
      "default": "./src/lib/server.ts"
    }
  },
  "scripts": {
    "generate": "bun run node_modules/routedjs/src/cli/index.ts generate",
    "generate:openapi": "bun run node_modules/routedjs/src/cli/index.ts openapi",
    "build": "tsc -b tsconfig.json",
    "dev": "./scripts/dev.sh",
    "format": "oxfmt src",
    "lint": "oxlint src",
    "start": "bun run src/app.ts",
    "test": "bun test src --pass-with-no-tests",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@lifecycle/agents": "workspace:*",
    "@lifecycle/contracts": "workspace:*",
    "@lifecycle/control-plane": "workspace:*",
    "@lifecycle/db": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "hono": "^4.7.10",
    "routedjs": "0.1.6",
    "zod": "^4.3.6"
  }
}
