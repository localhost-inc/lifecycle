{
  "extends": "../../packages/config/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": false,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "routes/**/*.ts", "routed.gen.ts", "routed.d.ts"],
  "exclude": ["src/**/*.test.ts"]
}
