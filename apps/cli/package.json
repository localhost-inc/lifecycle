{
  "name": "@lifecycle/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "lifecycle": "./src/index.ts"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "bridge:dev": "./scripts/bridge-dev.sh",
    "bridge:generate": "bunx routedjs generate",
    "bridge:generate:openapi": "bunx routedjs openapi",
    "build:release": "bun ./scripts/build-release.ts",
    "format": "oxfmt src scripts",
    "lint": "oxlint src scripts",
    "test": "bun test src",
    "typecheck": "tsc -b tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@lifecycle/contracts": "workspace:*",
    "@lifecycle/control-plane": "workspace:*",
    "@lifecycle/db": "workspace:*",
    "@localhost-inc/cmd": "^0.2.1",
    "@mariozechner/pi-agent-core": "^0.67.2",
    "@mariozechner/pi-ai": "^0.67.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentui/core": "^0.1.99",
    "@opentui/react": "^0.1.99",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-pty": "^0.4.8",
    "ghostty-opentui": "^1.4.10",
    "hono": "^4.7.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "routedjs": "0.1.6",
    "smol-toml": "^1.6.1",
    "zod": "^4.3.6"
  }
}
