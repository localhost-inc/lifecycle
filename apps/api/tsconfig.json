{
  "extends": "../../packages/config/tsconfig.app.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "types": ["@cloudflare/workers-types"],
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": false,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "routes/**/*.ts", "routed.gen.ts", "routed.client.ts", "routed.d.ts", "type-check.ts"],
  "exclude": ["src/index.ts", "src/**/*.test.ts", "src/dev.ts"]
}
