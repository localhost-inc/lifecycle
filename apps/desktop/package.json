  "repository": {
    "type": "git",
    "url": "git+https://github.com/localhost-inc/lifecycle.git"
  },
  "type": "module",
  "scripts": {
    "dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "dev:no-watch": "tauri dev --no-watch --config src-tauri/tauri.dev.conf.json",
    "build": "tauri build",
    "prepare:cli": "bun run scripts/prepare-lifecycle-cli.ts",
