{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lifecycle",
  "version": "0.1.0",
  "identifier": "dev.lifecycle.desktop",
  "mainBinaryName": "Lifecycle",
  "build": {
    "beforeDevCommand": "bun run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run prepare:cli && bun run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Lifecycle",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "acceptFirstMouse": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 24,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": ["resources/lifecycle*"],
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5ODQwQjgxQTJFREZCOEYKUldTUCsrMmlnUXVFT2FJazRCeGF3bGQwOGcxSjZxajIzNDRVTDhsNFZCaERiR1ZrYlFERUQ1K0kK",
      "endpoints": [
        "https://github.com/localhost-inc/lifecycle-releases/releases/latest/download/latest.json"
      ]
    }
  }
}
