{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lifecycle",
  "version": "0.1.0",
  "identifier": "com.lifecycle.desktop",
  "build": {
    "beforeDevCommand": "bun run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Lifecycle",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "acceptFirstMouse": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
